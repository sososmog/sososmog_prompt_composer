{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Composer",
  "version": "0.1.0",
  "identifier": "com.composer.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Composer",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
